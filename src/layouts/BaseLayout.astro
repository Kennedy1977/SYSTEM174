---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CookieConsentBanner from "../components/CookieConsentBanner.astro";
import PersistentSoundCloudPlayer from "../components/PersistentSoundCloudPlayer.astro";
import {
  siteAppleTouchIconPath,
  siteAnalyticsMeasurementId,
  siteConsentCookieDurationDays,
  siteConsentCookieName,
  siteDefaultDescription,
  siteFaviconIcoPath,
  siteFaviconPngPath,
  siteLocale,
  siteName,
  siteRobots,
  siteSocialImageAlt,
  siteSocialImagePath,
  siteStructuredData,
  siteThemeColor,
  siteTitle,
} from "../lib/site-meta";

const { title = siteTitle, description = siteDefaultDescription, robots = siteRobots } = Astro.props;
const analyticsMeasurementId = siteAnalyticsMeasurementId;
const consentCookieName = siteConsentCookieName;
const consentCookieMaxAge = siteConsentCookieDurationDays * 24 * 60 * 60;
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const socialImageUrl = Astro.site
  ? new URL(siteSocialImagePath, Astro.site).toString()
  : siteSocialImagePath;
const faviconIcoUrl = Astro.site
  ? new URL(siteFaviconIcoPath, Astro.site).toString()
  : siteFaviconIcoPath;
const faviconPngUrl = Astro.site
  ? new URL(siteFaviconPngPath, Astro.site).toString()
  : siteFaviconPngPath;
const appleTouchIconUrl = Astro.site
  ? new URL(siteAppleTouchIconPath, Astro.site).toString()
  : siteAppleTouchIconPath;
const isHomePage = Astro.url.pathname === "/";
---

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script
      is:inline
      define:vars={{ analyticsMeasurementId, consentCookieName, consentCookieMaxAge }}
    >
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function gtag() {
          window.dataLayer.push(arguments);
        };

      const deniedConsentState = {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
      };

      const readCookie = (name) => {
        const match = document.cookie.match(
          new RegExp(`(?:^|; )${name.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}=([^;]*)`),
        );
        return match ? decodeURIComponent(match[1]) : null;
      };

      const writeCookie = (name, value, maxAge) => {
        const parts = [`${name}=${encodeURIComponent(value)}`, `Max-Age=${maxAge}`, "Path=/", "SameSite=Lax"];
        if (window.location.protocol === "https:") {
          parts.push("Secure");
        }
        document.cookie = parts.join("; ");
      };

      const expireCookie = (name, domain) => {
        const parts = [
          `${name}=`,
          "Expires=Thu, 01 Jan 1970 00:00:00 GMT",
          "Max-Age=0",
          "Path=/",
          "SameSite=Lax",
        ];
        if (domain) {
          parts.push(`Domain=${domain}`);
        }
        if (window.location.protocol === "https:") {
          parts.push("Secure");
        }
        document.cookie = parts.join("; ");
      };

      const getCookieDomainCandidates = () => {
        const hostname = window.location.hostname;
        const hostParts = hostname.split(".");
        if (hostParts.length < 2) {
          return [hostname];
        }

        const baseDomain = hostParts.slice(-2).join(".");
        return Array.from(new Set([hostname, `.${hostname}`, baseDomain, `.${baseDomain}`]));
      };

      const clearAnalyticsCookies = () => {
        const measurementSuffix = analyticsMeasurementId.replace(/^G-/, "");
        const cookieNames = ["_ga", `_ga_${measurementSuffix}`];
        const domains = [undefined, ...getCookieDomainCandidates()];

        cookieNames.forEach((cookieName) => {
          domains.forEach((domain) => {
            expireCookie(cookieName, domain);
          });
        });
      };

      const parseStoredConsent = () => {
        const rawValue = readCookie(consentCookieName);
        if (!rawValue) return null;

        try {
          const parsed = JSON.parse(rawValue);
          if (typeof parsed?.analytics !== "boolean") {
            return null;
          }

          return {
            analytics: parsed.analytics,
            updatedAt: typeof parsed.updatedAt === "string" ? parsed.updatedAt : null,
          };
        } catch {
          return null;
        }
      };

      const getStoredConsentState = () => {
        const parsed = parseStoredConsent();
        return {
          hasDecision: Boolean(parsed),
          analytics: parsed?.analytics === true,
          updatedAt: parsed?.updatedAt ?? null,
        };
      };

      const applyGoogleConsent = (analyticsGranted) => {
        if (!analyticsGranted) {
          clearAnalyticsCookies();
        }

        window.gtag("consent", "update", {
          ...deniedConsentState,
          analytics_storage: analyticsGranted ? "granted" : "denied",
        });
      };

      const trackPageView = () => {
        const consentState = getStoredConsentState();
        if (!consentState.analytics) return;

        const pageKey = `${window.location.pathname}${window.location.search}${window.location.hash}`;
        if (window.__system174LastTrackedPage === pageKey) {
          return;
        }

        window.__system174LastTrackedPage = pageKey;
        window.gtag("event", "page_view", {
          page_title: document.title,
          page_location: window.location.href,
          page_path: `${window.location.pathname}${window.location.search}`,
        });
      };

      window.system174ConsentManager = {
        cookieName: consentCookieName,
        cookieMaxAge: consentCookieMaxAge,
        getState: getStoredConsentState,
        setAnalyticsConsent: (analyticsGranted) => {
          writeCookie(
            consentCookieName,
            JSON.stringify({
              analytics: Boolean(analyticsGranted),
              updatedAt: new Date().toISOString(),
              version: 1,
            }),
            consentCookieMaxAge,
          );

          applyGoogleConsent(Boolean(analyticsGranted));

          const state = getStoredConsentState();
          window.dispatchEvent(new CustomEvent("system174:consent-updated", { detail: state }));

          if (state.analytics) {
            trackPageView();
          }
        },
        openSettings: () => {
          window.dispatchEvent(new Event("system174:open-cookie-settings"));
        },
        trackPageView,
      };

      if (!window.__system174AnalyticsInitialized) {
        window.gtag("consent", "default", {
          ...deniedConsentState,
          wait_for_update: 500,
        });

        const storedConsentState = getStoredConsentState();
        if (storedConsentState.hasDecision) {
          applyGoogleConsent(storedConsentState.analytics);
        }
      }

      if (!window.__system174AnalyticsPageLoadBound) {
        const handlePageLoad = () => {
          window.system174ConsentManager?.trackPageView?.();
        };

        window.addEventListener("load", handlePageLoad, { once: true });
        document.addEventListener("astro:page-load", handlePageLoad);
        window.__system174AnalyticsPageLoadBound = true;
      }
    </script>
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-0EDDDZ0WGG"
    ></script>
    <script is:inline define:vars={{ analyticsMeasurementId }}>
      if (!window.__system174AnalyticsInitialized) {
        window.gtag("set", "ads_data_redaction", true);
        window.gtag("js", new Date());
        window.gtag("config", analyticsMeasurementId, {
          anonymize_ip: true,
          send_page_view: false,
        });

        window.__system174AnalyticsInitialized = true;
      }
    </script>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content={siteThemeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content={siteLocale} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={siteSocialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <ClientRouter />
    <link rel="icon" href={faviconIcoUrl} sizes="any" />
    <link rel="icon" type="image/png" href={faviconPngUrl} />
    <link rel="apple-touch-icon" href={appleTouchIconUrl} />
    {isHomePage && <script type="application/ld+json" set:html={JSON.stringify(siteStructuredData)} />}
    <slot name="head" />
    <title>{title}</title>
  </head>
  <body class="site-bg">
    <div class="site-bg-main"></div>
    <CookieConsentBanner />
    <div class="site-content">
      <Nav currentPath={Astro.url.pathname} />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
    <PersistentSoundCloudPlayer />
  </body>
</html>
