---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import ButtonPrimary from "../components/ButtonPrimary.astro";
import ButtonSecondary from "../components/ButtonSecondary.astro";
import BadgeStatus from "../components/BadgeStatus.astro";
import ShowRow from "../components/ShowRow.astro";
import EmbedFrame from "../components/EmbedFrame.astro";
import FormField from "../components/FormField.astro";
import { upcomingShows } from "../data/site";
import { getSoundCloudDashboardData } from "../lib/soundcloud";

const soundcloud = await getSoundCloudDashboardData();
const latestTrack = soundcloud.tracks.find((track) => {
  const title = track.title.toLowerCase();
  return !title.includes("remix") && !title.includes("cover") && !title.includes("bootleg");
});
const featuredPlaylist = soundcloud.playlists[0];
---

<BaseLayout title="System 174 | Home">
  <Section>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8" id="home">
      <div class="md:col-span-8">
        <p class="label-ui">Liverpool, UK</p>
        <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl tracking-[-0.02em] uppercase text-white">
          SYSTEM <span class="text-accent">174</span>
        </h1>
        <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">174 BPM pressure engineered. No halftime.</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <ButtonPrimary href="/music">LISTEN</ButtonPrimary>
          <ButtonSecondary href="/contact">BOOKINGS</ButtonSecondary>
        </div>
      </div>
      <div class="md:col-span-4">
        <Card>
          <p class="label-ui">LATEST DROP</p>
          <div class="mt-4"><BadgeStatus status="NEW" /></div>
          <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">Pressure Archive 01 is live across all platforms.</p>
        </Card>
      </div>
    </div>
  </Section>

  <Section title="LATEST RELEASE">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-7">
        <Card>
          <p class="label-ui">Latest Track</p>
          {latestTrack ? (
            <>
              <h3 class="mt-3 font-display text-xl md:text-2xl tracking-[-0.01em] uppercase">{latestTrack.title}</h3>
              <p class="mt-2 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
                {new Date(latestTrack.created_at).toLocaleDateString()}
              </p>
            </>
          ) : (
            <p class="mt-3 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
              Latest release will appear here when tracks are available.
            </p>
          )}
        </Card>
      </div>
      <div class="md:col-span-5">
        <EmbedFrame title="SOUNDCLOUD PLAYER" url={latestTrack?.permalink_url} />
      </div>
    </div>
  </Section>

  <Section title="UPCOMING SHOWS">
    <Card>
      {upcomingShows.slice(0, 3).map((show) => <ShowRow show={show} />)}
    </Card>
    <div class="mt-5">
      <ButtonSecondary href="/shows">View all shows</ButtonSecondary>
    </div>
  </Section>

  <Section title="FEATURED MIX">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-8">
        <EmbedFrame title={featuredPlaylist ? featuredPlaylist.title : "FEATURED PLAYLIST"} url={featuredPlaylist?.permalink_url} />
      </div>
      <div class="md:col-span-4">
        <Card>
          <p class="label-ui">Playlist</p>
          {featuredPlaylist ? (
            <>
              <p class="mt-3 font-body text-[15px] leading-relaxed text-[#AAB6C6]">{featuredPlaylist.title}</p>
            </>
          ) : (
            <p class="mt-3 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
              No playlist available yet.
            </p>
          )}
        </Card>
      </div>
    </div>
  </Section>

  <Section title="ABOUT" description="Pressure-driven club constructions from SYSTEM 174. Built for dense rooms and long transitions. No excess, only function.">
    <ButtonSecondary href="/media">MEDIA KIT</ButtonSecondary>
  </Section>

  <Section title="NEWSLETTER">
    <div class="max-w-xl">
      <form class="space-y-4">
        <FormField label="Email" name="email" type="email" placeholder="you@domain.com" />
        <ButtonPrimary type="submit">SUBSCRIBE</ButtonPrimary>
      </form>
    </div>
  </Section>
</BaseLayout>
