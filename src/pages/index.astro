---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import ButtonPrimary from "../components/ButtonPrimary.astro";
import BadgeStatus from "../components/BadgeStatus.astro";
import { getSoundCloudDashboardData } from "../lib/soundcloud";

const fallbackCoverUrl = "/textures/bg-main.png";
const getPlayerUrl = (url: string) =>
  `https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=%235CC8FF&auto_play=true&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false`;
const soundcloud = await getSoundCloudDashboardData();
const selectedTracks = soundcloud.tracks
  .filter((track) => {
    const genre = (track.genre ?? "").trim().toLowerCase();
    const sharing = (track.sharing ?? "").toLowerCase();
    const isBlocked = (track.access ?? "")
      .toLowerCase()
      .split(",")
      .map((part) => part.trim())
      .includes("blocked");
    return genre === "drum & bass" && sharing !== "private" && !isBlocked;
  })
  .sort((a, b) => {
    const likeDiff = (b.favoritings_count ?? 0) - (a.favoritings_count ?? 0);
    if (likeDiff !== 0) return likeDiff;
    const playDiff = (b.playback_count ?? 0) - (a.playback_count ?? 0);
    if (playDiff !== 0) return playDiff;
    return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
  })
  .slice(0, 4)
  .map((track) => ({
    title: track.title,
    href: track.permalink_url,
    soundcloudUrl: track.permalink_url,
    artworkUrl: track.artwork_url ?? "",
    genre: track.genre ?? "",
  }));
const initialInlinePlayerUrl = selectedTracks[0]?.soundcloudUrl
  ? getPlayerUrl(selectedTracks[0].soundcloudUrl).replace("auto_play=true", "auto_play=false")
  : "";
---

<BaseLayout title="System 174 | Home">
  <Section>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8" id="home">
      <div class="md:col-span-8">
        <p class="label-ui">Liverpool, UK</p>
        <h1 class="mt-4 font-brand text-4xl md:text-5xl lg:text-6xl tracking-[-0.02em] uppercase text-white">
          SYSTEM <span class="text-accent">174</span>
        </h1>
        <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
          SYSTEM 174 is dark, rolling drum &amp; bass built for pressure rather than spectacle. It runs at full 174 BPM, driven by tight breakbeats and a solid two-step backbone that keeps the groove locked in.
        </p>
        <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
          The bass is usually a deep, sustained Reese or heavy sub, evolving slowly instead of wobbling all over the place. Atmospheres lean industrial, metallic textures, distant drones, and sparse melodies that create tension without overcrowding the mix.
        </p>
        <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
          Tracks are arranged for DJs, with long intros, extended rolling sections, and clean outros for easy blending. Vocals are minimal, maybe a ragga toast or a short sample, but the focus stays on the groove.
        </p>
        <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
          In short, SYSTEM 174 is controlled, underground drum &amp; bass pressure, cold, mechanical, and built for dark rooms and big sound systems.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <ButtonPrimary href="/music">LISTEN</ButtonPrimary>
        </div>
      </div>
      <div class="md:col-span-4">
        <Card>
          <p class="label-ui">LATEST DROP</p>
          <div class="mt-4"><BadgeStatus status="NEW" /></div>
          <h3 class="mt-4 font-display text-xl tracking-[-0.01em] uppercase">Chasing Shadows</h3>
          <p class="mt-2 font-body text-[14px] leading-relaxed text-[#AAB6C6]">SYSTEM 174</p>
          <p class="mt-3 font-body text-[14px] leading-relaxed text-[#AAB6C6]">Release Date: 20 March 2026</p>
          <p class="font-body text-[14px] leading-relaxed text-[#AAB6C6]">Genre: Dance</p>
          <p class="font-body text-[14px] leading-relaxed text-[#AAB6C6]">Sub Genre: Jungle/Drum'n'bass</p>
          <p class="font-body text-[14px] leading-relaxed text-[#AAB6C6]">Label: SYSTEM 174</p>
          <p class="font-body text-[14px] leading-relaxed text-[#AAB6C6]">UPC: 823191180401</p>
          <a
            href="/playlists?genre=Drum+%26+Bass&playlist=2199354848"
            class="mt-4 inline-block text-sm font-semibold tracking-[0.04em] text-accent hover:text-white transition-colors"
          >
            VIEW RELEASE
          </a>
        </Card>
      </div>
    </div>
  </Section>

  <Section title="SELECTED TRACKS">
    <iframe
      id="inline-home-sc-player"
      class="absolute h-0 w-0 opacity-0 pointer-events-none"
      title="Home Selected Tracks Player"
      src={initialInlinePlayerUrl}
      loading="lazy"
      allow="autoplay"
    />
    {selectedTracks.length === 0 ? (
      <Card>
        <p class="font-body text-[15px] leading-relaxed text-[#AAB6C6]">
          No Drum &amp; Bass tracks are currently available.
        </p>
      </Card>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-6">
        {selectedTracks.map((track) => (
          <article class="group rounded-2xl border border-white/10 bg-[#11151C]/60 overflow-hidden hover:border-[#5CC8FF]/40 transition duration-150 ease-out">
            <button
              type="button"
              data-home-sc-play={getPlayerUrl(track.soundcloudUrl || track.href)}
              data-home-sc-pause={getPlayerUrl(track.soundcloudUrl || track.href).replace("auto_play=true", "auto_play=false")}
              class="block w-full text-left"
              aria-label={`Play ${track.title}`}
            >
              <div class="relative aspect-square w-full bg-[#1A2230] bg-cover bg-center" style={`background-image:url('${fallbackCoverUrl}')`}>
                {track.artworkUrl ? (
                  <img
                    src={track.artworkUrl}
                    alt={track.title}
                    onerror="this.style.display='none'"
                    class="h-full w-full object-cover opacity-95 group-hover:opacity-100 transition duration-150 ease-out"
                  />
                ) : null}
                <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/25 opacity-0 transition duration-150 ease-out group-hover:opacity-100">
                  <span data-home-icon-toggle class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#0A0C10]/70 text-[#E7EDF6]">
                    ▶
                  </span>
                </div>
              </div>
            </button>
            <div class="p-3">
              <p class="text-sm font-semibold tracking-tight text-[#E7EDF6]">{track.title}</p>
              {track.genre && <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[#77849A]">{track.genre}</p>}
              <a
                href={track.href}
                class="mt-3 inline-block text-xs font-semibold tracking-[0.12em] text-accent hover:text-white transition-colors"
              >
                OPEN
              </a>
            </div>
          </article>
        ))}
      </div>
    )}
  </Section>

</BaseLayout>

<script is:inline>
  (() => {
    const player = document.getElementById("inline-home-sc-player");
    if (!(player instanceof HTMLIFrameElement)) return;

    const buttons = Array.from(document.querySelectorAll("[data-home-sc-play]"));
    let currentButton = null;
    let isPlaying = false;

    const setIcon = (button, playing) => {
      const icon = button?.querySelector("[data-home-icon-toggle]");
      if (!icon) return;
      icon.textContent = playing ? "❚❚" : "▶";
    };

    for (const button of buttons) {
      if (!(button instanceof HTMLButtonElement)) continue;
      button.addEventListener("click", () => {
        const playSrc = button.getAttribute("data-home-sc-play");
        const pauseSrc = button.getAttribute("data-home-sc-pause");
        if (!playSrc || !pauseSrc) return;

        if (currentButton === button && isPlaying) {
          player.src = pauseSrc;
          setIcon(button, false);
          isPlaying = false;
          return;
        }

        if (currentButton && currentButton !== button) {
          setIcon(currentButton, false);
        }

        player.src = playSrc;
        setIcon(button, true);
        currentButton = button;
        isPlaying = true;
      });
    }
  })();
</script>
