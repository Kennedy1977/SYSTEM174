---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import ButtonPrimary from "../components/ButtonPrimary.astro";
import ButtonSecondary from "../components/ButtonSecondary.astro";
import BadgeStatus from "../components/BadgeStatus.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import ShowRow from "../components/ShowRow.astro";
import EmbedFrame from "../components/EmbedFrame.astro";
import FormField from "../components/FormField.astro";
import { releases, upcomingShows } from "../data/site";
---

<BaseLayout title="Controlled Detonation | Home">
  <Section>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8" id="home">
      <div class="md:col-span-8">
        <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Berlin, DE</p>
        <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-[-0.02em] uppercase">CONTROLLED DETONATION</h1>
        <p class="mt-4 text-[15px] leading-relaxed text-[#AAB6C6]">174 BPM pressure engineered. No halftime.</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <ButtonPrimary href="/music">LISTEN</ButtonPrimary>
          <ButtonSecondary href="/contact">BOOKINGS</ButtonSecondary>
        </div>
      </div>
      <div class="md:col-span-4">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">LATEST DROP</p>
          <div class="mt-4"><BadgeStatus status="NEW" /></div>
          <p class="mt-4 text-[15px] leading-relaxed text-[#AAB6C6]">Pressure Archive 01 is live across all platforms.</p>
        </Card>
      </div>
    </div>
  </Section>

  <Section title="LATEST RELEASE">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-7">
        <ReleaseCard release={releases[0]} featured={true} />
      </div>
      <div class="md:col-span-5">
        <EmbedFrame title="SoundCloud / Bandcamp / Spotify" />
      </div>
    </div>
  </Section>

  <Section title="UPCOMING SHOWS">
    <Card>
      {upcomingShows.slice(0, 3).map((show) => <ShowRow show={show} />)}
    </Card>
    <div class="mt-5">
      <ButtonSecondary href="/shows">View all shows</ButtonSecondary>
    </div>
  </Section>

  <Section title="FEATURED MIX">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-8">
        <EmbedFrame title="PRESSURE FEED 074" />
      </div>
      <div class="md:col-span-4">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Tracklist</p>
          <a href="#" class="mt-3 inline-flex text-sm text-[#AAB6C6] hover:text-[#E7EDF6] transition duration-150 ease-out">Open tracklist</a>
        </Card>
      </div>
    </div>
  </Section>

  <Section title="ABOUT" description="Pressure-driven club constructions from CONTROLLED DETONATION. Built for dense rooms and long transitions. No excess, only function.">
    <ButtonSecondary href="/media">MEDIA KIT</ButtonSecondary>
  </Section>

  <Section title="NEWSLETTER">
    <div class="max-w-xl">
      <form class="space-y-4">
        <FormField label="Email" name="email" type="email" placeholder="you@domain.com" />
        <ButtonPrimary type="submit">SUBSCRIBE</ButtonPrimary>
      </form>
    </div>
  </Section>
</BaseLayout>
