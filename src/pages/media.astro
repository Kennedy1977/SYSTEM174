---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import MediaDownloadCard from "../components/MediaDownloadCard.astro";
import Card from "../components/Card.astro";
import ButtonSecondary from "../components/ButtonSecondary.astro";
import { mediaDownloads } from "../data/site";
---

<BaseLayout title="Controlled Detonation | Media">
  <Section title="MEDIA KIT" description="Press assets and documents for promoters, venues, and editorial.">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          {mediaDownloads.map((item) => <MediaDownloadCard item={item} />)}
        </div>
      </div>
      <div class="md:col-span-4 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Short Bio</p>
          <p class="mt-3 text-[15px] leading-relaxed text-[#AAB6C6]">CONTROLLED DETONATION engineers dark, high-pressure sets optimized for industrial rooms and peak-hour endurance.</p>
          <div class="mt-4"><ButtonSecondary>COPY</ButtonSecondary></div>
        </Card>
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Booking</p>
          <p class="mt-3 text-sm text-[#AAB6C6]">booking@controlled-detonation.com</p>
        </Card>
      </div>
    </div>
  </Section>
</BaseLayout>
