---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import ButtonPrimary from "../components/ButtonPrimary.astro";
import FormField from "../components/FormField.astro";
import SocialPlatformIcon from "../components/SocialPlatformIcon.astro";

const system174Links = [
  {
    label: "SoundCloud",
    platform: "soundcloud",
    href: "https://soundcloud.com/system174",
  },
  {
    label: "Amazon Music",
    platform: "amazon-music",
    href: "https://music.amazon.de/artists/B0GRB5V6SD/system-174",
  },
] as const;

const pimpsoulLinks = [
  {
    label: "SoundCloud",
    platform: "soundcloud",
    href: "https://soundcloud.com/system174",
  },
  {
    label: "Apple Music",
    platform: "apple-music",
    href: "https://music.apple.com/gb/artist/the-pimpsoul-project/1750852619",
  },
  {
    label: "Amazon Music",
    platform: "amazon-music",
    href: "https://music.amazon.com/artists/B0D5FP86SF/the-pimpsoul-project",
  },
  {
    label: "YouTube",
    platform: "youtube",
    href: "https://www.youtube.com/@PIMPSOUL",
  },
  {
    label: "YouTube Music",
    platform: "youtube-music",
    href: "https://music.youtube.com/channel/UC1Vsx7jaPa0oXfvC9QLNZaA",
  },
  {
    label: "Instagram",
    platform: "instagram",
    href: "https://www.instagram.com/thepimpsoulproject/",
  },
] as const;
---

<BaseLayout title="System 174 | Contact">
  <Section title="CONTACT" description="Bookings and media requests.">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">
      <div class="md:col-span-7">
        <Card>
          <form class="space-y-4">
            <FormField label="Name" name="name" placeholder="Your name" />
            <FormField label="Email" name="email" type="email" placeholder="you@domain.com" />
            <FormField label="Subject" name="subject" placeholder="Booking inquiry" />
            <FormField label="Message" name="message" textarea={true} rows={5} placeholder="City, date, venue capacity, budget." helper="We reply within 48 hours." />
            <ButtonPrimary type="submit">SEND</ButtonPrimary>
          </form>
        </Card>
      </div>
      <div class="md:col-span-5 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Management</p>
          <p class="mt-3 text-sm text-[#AAB6C6]">UNIT 174 MANAGEMENT</p>
          <p class="mt-1 text-sm text-[#E7EDF6]">mgmt@umsl.co.uk</p>
        </Card>

        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">SYSTEM 174</p>
          <ul class="mt-4 space-y-3">
            {system174Links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex items-center gap-3 rounded-xl border border-white/10 bg-[#0A0C10]/40 px-3 py-3 transition duration-150 ease-out hover:border-[#5CC8FF]/50 hover:bg-[#5CC8FF]/5"
                >
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[#E7EDF6] transition-colors group-hover:text-[#5CC8FF]">
                    <SocialPlatformIcon platform={link.platform} class="h-4.5 w-4.5" />
                  </span>
                  <span class="font-body text-sm text-[#E7EDF6]">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </Card>

        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">THE PIMPSOUL PROJECT</p>
          <ul class="mt-4 space-y-3">
            {pimpsoulLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex items-center gap-3 rounded-xl border border-white/10 bg-[#0A0C10]/40 px-3 py-3 transition duration-150 ease-out hover:border-[#5CC8FF]/50 hover:bg-[#5CC8FF]/5"
                >
                  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[#E7EDF6] transition-colors group-hover:text-[#5CC8FF]">
                    <SocialPlatformIcon platform={link.platform} class="h-4.5 w-4.5" />
                  </span>
                  <span class="font-body text-sm text-[#E7EDF6]">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </Card>
      </div>
    </div>
  </Section>
</BaseLayout>
