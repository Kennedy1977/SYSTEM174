---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import SocialPlatformIcon from "../components/SocialPlatformIcon.astro";

const system174Links = [
  {
    label: "SoundCloud",
    platform: "soundcloud",
    href: "https://soundcloud.com/system174",
    note: "Direct profile",
  },
  {
    label: "Spotify",
    platform: "spotify",
    href: "https://open.spotify.com/artist/3atPE4TuVWhu8uV9p0QbH6",
    note: "Verified artist page",
  },
  {
    label: "Apple Music",
    platform: "apple-music",
    href: "https://music.apple.com/gb/artist/system-174/1882690381",
    note: "Verified artist page",
  },
  {
    label: "Amazon Music",
    platform: "amazon-music",
    href: "https://music.amazon.co.uk/artists/B0GR9Z1SFX/system-174",
    note: "UK artist page",
  },
] as const;

const pimpsoulLinks = [
  {
    label: "SoundCloud",
    platform: "soundcloud",
    href: "https://soundcloud.com/system174",
  },
  {
    label: "Apple Music",
    platform: "apple-music",
    href: "https://music.apple.com/gb/artist/the-pimpsoul-project/1750852619",
  },
  {
    label: "Amazon Music",
    platform: "amazon-music",
    href: "https://music.amazon.com/artists/B0D5FP86SF/the-pimpsoul-project",
  },
  {
    label: "YouTube",
    platform: "youtube",
    href: "https://www.youtube.com/@PIMPSOUL",
  },
  {
    label: "YouTube Music",
    platform: "youtube-music",
    href: "https://music.youtube.com/channel/UC1Vsx7jaPa0oXfvC9QLNZaA",
  },
  {
    label: "Instagram",
    platform: "instagram",
    href: "https://www.instagram.com/thepimpsoulproject/",
  },
] as const;
---

<BaseLayout title="System 174 | Contact">
  <Section
    title="CONTACT"
    description="Management, verified platform links, and legacy project outlets."
    headingLevel={1}
  >
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-7 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">CURRENT PROJECT</p>
          <h2 class="mt-3 font-display text-2xl tracking-[-0.01em] uppercase text-white">SYSTEM 174</h2>
          <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
            The active project. Dark, DJ-focused drum &amp; bass built for pressure, with current artist pages verified across the main streaming platforms below.
          </p>
          <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
            {system174Links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="group flex items-center gap-4 rounded-xl border border-white/10 bg-[#0A0C10]/40 px-4 py-3 transition duration-150 ease-out hover:border-[#5CC8FF]/50 hover:bg-[#5CC8FF]/5"
              >
                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center text-[#E7EDF6] transition-colors group-hover:text-[#5CC8FF]">
                  <SocialPlatformIcon platform={link.platform} class="h-6 w-6" />
                </span>
                <span class="min-w-0">
                  <span class="block font-body text-sm text-[#E7EDF6]">{link.label}</span>
                  <span class="mt-1 block text-xs text-[#77849A]">{link.note}</span>
                </span>
              </a>
            ))}
          </div>
        </Card>

        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Management</p>
          <p class="mt-3 text-sm text-[#AAB6C6]">UNIT 174 MANAGEMENT</p>
          <a href="mailto:mgmt@umsl.co.uk" class="mt-1 inline-block text-base text-[#E7EDF6] hover:text-[#5CC8FF] transition-colors">
            mgmt@umsl.co.uk
          </a>
          <p class="mt-4 font-body text-[14px] leading-relaxed text-[#77849A]">
            For bookings, press, radio, or release enquiries, use the management address above.
          </p>
        </Card>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">LEGACY PROJECT</p>
          <h2 class="mt-3 font-display text-2xl tracking-[-0.01em] uppercase text-white">THE PIMPSOUL PROJECT</h2>
          <p class="mt-4 font-body text-[15px] leading-relaxed text-[#AAB6C6]">
            Archive links for the completed crossover chapter. No new releases are planned under this name, but the catalogue remains live across the outlets below.
          </p>
          <ul class="mt-4 space-y-3">
            {pimpsoulLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  class="group flex items-center gap-4 rounded-xl border border-white/10 bg-[#0A0C10]/40 px-3 py-3 transition duration-150 ease-out hover:border-[#5CC8FF]/50 hover:bg-[#5CC8FF]/5"
                >
                  <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center text-[#E7EDF6] transition-colors group-hover:text-[#5CC8FF]">
                    <SocialPlatformIcon platform={link.platform} class="h-6 w-6" />
                  </span>
                  <span class="font-body text-sm text-[#E7EDF6]">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </Card>

        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">NOTES</p>
          <p class="mt-3 font-body text-[14px] leading-relaxed text-[#AAB6C6]">
            Verified for SYSTEM 174: SoundCloud, Spotify, Apple Music, and Amazon Music. Amazon appears to use region-specific artist URLs, so this page uses the UK artist page.
          </p>
          <p class="mt-4 font-body text-[14px] leading-relaxed text-[#77849A]">
            I did not find a clearly verified official Instagram, YouTube, or Bandcamp profile for SYSTEM 174 during this pass, so I left those off rather than guessing.
          </p>
        </Card>
      </div>
    </div>
  </Section>
</BaseLayout>
