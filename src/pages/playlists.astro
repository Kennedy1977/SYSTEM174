---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import { getSoundCloudDashboardData } from "../lib/soundcloud";
import { buildSystem174Catalog } from "../lib/soundcloud-catalog";
import { isSoundCloudPaginationEnabled } from "../lib/site-config";

const soundcloud = buildSystem174Catalog(await getSoundCloudDashboardData());
const playlists = soundcloud.playlists;
const selectedGenre = (Astro.url.searchParams.get("genre") ?? "").trim();
const selectedGenreKey = selectedGenre.toLowerCase();
const search = (Astro.url.searchParams.get("q") ?? "").trim();
const searchKey = search.toLowerCase();
const selectedPlaylistIdRaw = Number(Astro.url.searchParams.get("playlist") ?? "");
const selectedPlaylistId = Number.isFinite(selectedPlaylistIdRaw) ? selectedPlaylistIdRaw : null;
const paginationEnabled = isSoundCloudPaginationEnabled();
const PLAYLISTS_PAGE_SIZE = 12;
const PLAYLISTS_BATCH_SIZE = 12;
const PLAYLISTS_INITIAL_COUNT = 24;
const rawPage = Number(Astro.url.searchParams.get("page") ?? "1");
const requestedPage = Number.isFinite(rawPage) ? Math.max(1, Math.floor(rawPage)) : 1;

const isCoverOrBootleg = (item: { title: string }) => {
  const title = item.title.toLowerCase();
  return title.includes("cover") || title.includes("bootleg");
};

const isPrivateTrack = (item: { sharing?: string | null }) => (item.sharing ?? "").toLowerCase() === "private";
const isBlockedByAccess = (item: { access?: string | null }) =>
  (item.access ?? "")
    .toLowerCase()
    .split(",")
    .map((part) => part.trim())
    .includes("blocked");

const visiblePlaylists = playlists.filter((playlist) => !isCoverOrBootleg(playlist));

const allGenres = Array.from(new Set(visiblePlaylists.map((item) => (item.genre ?? "").trim()).filter(Boolean))).sort((a, b) =>
  a.localeCompare(b),
);

const byGenre = selectedGenre
  ? visiblePlaylists.filter((playlist) => (playlist.genre ?? "").trim().toLowerCase() === selectedGenreKey)
  : visiblePlaylists;

const filteredPlaylists = searchKey
  ? byGenre.filter((playlist) => playlist.title.toLowerCase().includes(searchKey))
  : byGenre;

const selectedPlaylist = selectedPlaylistId
  ? visiblePlaylists.find((playlist) => playlist.id === selectedPlaylistId) ?? null
  : null;

const totalPages = Math.max(1, Math.ceil(filteredPlaylists.length / PLAYLISTS_PAGE_SIZE));
const currentPage = Math.min(requestedPage, totalPages);
const startIndex = (currentPage - 1) * PLAYLISTS_PAGE_SIZE;

const buildUrl = (overrides?: { genre?: string | null; q?: string | null; playlist?: number | null; page?: number | null }) => {
  const params = new URLSearchParams();
  const genre = overrides?.genre === undefined ? selectedGenre : overrides.genre ?? "";
  const q = overrides?.q === undefined ? search : overrides.q ?? "";
  const playlistId = overrides?.playlist === undefined ? selectedPlaylist?.id ?? null : overrides.playlist;
  const page = overrides?.page === undefined ? (paginationEnabled ? currentPage : null) : overrides.page;
  if (genre) params.set("genre", genre);
  if (q) params.set("q", q);
  if (paginationEnabled && page && page > 1) params.set("page", String(page));
  if (playlistId) params.set("playlist", String(playlistId));
  const query = params.toString();
  return query ? `/playlists?${query}` : "/playlists";
};

const fallbackCoverUrl = "/textures/bg-main.png";
const getPlayerUrl = (url: string) =>
  `https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=%235CC8FF&auto_play=true&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false`;
const clientPlaylistsJson = JSON.stringify(filteredPlaylists).replaceAll("<", "\\u003c");
const initialPlaylists = filteredPlaylists.slice(0, PLAYLISTS_INITIAL_COUNT);
const paginatedPlaylists = filteredPlaylists.slice(startIndex, startIndex + PLAYLISTS_PAGE_SIZE);
const visibleLibraryPlaylists = paginationEnabled ? paginatedPlaylists : initialPlaylists;
const selectedPlaylistVisibleTracks = (selectedPlaylist?.tracks ?? []).filter(
  (track) => !isPrivateTrack(track) && !isBlockedByAccess(track),
);
---

<BaseLayout title="System 174 | Playlists">
  <Section title="PLAYLISTS" description="All SoundCloud playlists, synced automatically." headingLevel={1}>
    {!selectedPlaylist && (
      <div class="mb-10 rounded-2xl border border-white/10 bg-[#11151C]/70 p-5 sm:p-6">
        <form method="get" action="/playlists" class="grid grid-cols-1 gap-4 md:max-w-sm" data-playlist-filter-form>
          {search && <input type="hidden" name="q" value={search} />}
          <div>
            <label for="playlist-filter-genre" class="label-ui">Genre</label>
            <select
              id="playlist-filter-genre"
              name="genre"
              class="mt-3 w-full rounded-xl border border-white/10 bg-[#1A2230] px-3 py-3 text-sm text-[#E7EDF6] focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/50 focus:border-[#5CC8FF]/50"
            >
              <option value="">All genres</option>
              {allGenres.map((genre) => (
                <option value={genre} selected={genre.toLowerCase() === selectedGenreKey}>{genre}</option>
              ))}
            </select>
          </div>
          <noscript>
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold bg-[#1A2230] border border-white/10 text-[#E7EDF6] hover:bg-[#1A2230]/80 hover:border-white/20 transition duration-150 ease-out"
            >
              Apply filters
            </button>
          </noscript>
        </form>
      </div>
    )}

    <div class="mb-12">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h3 class="font-display text-xl md:text-2xl tracking-[-0.01em] uppercase">
            {selectedPlaylist ? selectedPlaylist.title : "Playlist Library"}
          </h3>
          {selectedPlaylist && (
            <div class="mt-2 flex items-center gap-2 text-xs uppercase tracking-[0.12em] text-[#AAB6C6]">
              <a href={buildUrl({ playlist: null })} class="hover:text-[#E7EDF6] transition duration-150 ease-out">
                Playlist Library
              </a>
              <span>/</span>
              <span class="text-[#E7EDF6]">{selectedPlaylist.title}</span>
            </div>
          )}
        </div>
        {!selectedPlaylist && (
          <form method="get" action="/playlists" class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row" data-live-search-form>
            <label for="playlist-search" class="sr-only">Search playlists</label>
            <input
              type="search"
              name="q"
              id="playlist-search"
              value={search}
              placeholder="Search playlists"
              class="w-full rounded-xl bg-[#0A0C10]/40 border border-white/10 px-3 py-2 text-sm text-[#E7EDF6] placeholder:text-[#77849A] focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/50 focus:border-[#5CC8FF]/50 sm:w-64"
            />
            {selectedGenre && <input type="hidden" name="genre" value={selectedGenre} />}
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold bg-[#1A2230] border border-white/10 text-[#E7EDF6] hover:bg-[#1A2230]/80 hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/40 focus:ring-offset-2 focus:ring-offset-[#0A0C10] transition duration-150 ease-out"
            >
              Search
            </button>
            {search && (
              <a
                href={buildUrl({ q: null, page: null })}
                class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border border-white/10 text-[#AAB6C6] hover:text-[#E7EDF6] hover:border-white/20 transition duration-150 ease-out"
              >
                Clear
              </a>
            )}
          </form>
        )}
      </div>
      {selectedPlaylist ? (
        <div class="mt-4 space-y-3">
          <a
            href={buildUrl({ playlist: null })}
            class="inline-flex items-center justify-center rounded-xl border border-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-[#AAB6C6] hover:text-[#E7EDF6] hover:border-[#5CC8FF]/40 transition duration-150 ease-out"
          >
            Back to Playlist Library
          </a>
          {selectedPlaylistVisibleTracks.length === 0 ? (
            <Card>
              <p class="font-body text-[15px] leading-relaxed text-[#AAB6C6]">No tracks were returned for this playlist.</p>
            </Card>
          ) : (
            <div class="rounded-2xl border border-white/10 bg-[#11151C]/70 p-4 sm:p-5">
              <p class="label-ui">Tracks</p>
              <div class="mt-3 divide-y divide-white/10">
                {selectedPlaylistVisibleTracks.map((track, index) => (
                  <button
                    type="button"
                    data-sc-source={`https://api.soundcloud.com/tracks/${track.id}`}
                    data-sc-play={getPlayerUrl(`https://api.soundcloud.com/tracks/${track.id}`)}
                    data-sc-pause={getPlayerUrl(`https://api.soundcloud.com/tracks/${track.id}`).replace("auto_play=true", "auto_play=false")}
                    data-sc-title={track.title ?? `Track ${index + 1}`}
                    data-sc-artwork={selectedPlaylist?.artwork_url ?? ""}
                    class="w-full text-left py-3 flex items-center justify-between gap-3 hover:bg-white/[0.02] transition duration-150 ease-out"
                    aria-label={`Play ${track.title ?? `Track ${index + 1}`}`}
                  >
                    <span class="text-sm text-[#E7EDF6]">
                      <span class="text-[#77849A] mr-2">{index + 1}.</span>{track.title ?? `Track ${index + 1}`}
                    </span>
                    <span data-icon-toggle class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#0A0C10]/70 text-[#E7EDF6]">
                      ▶
                    </span>
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      ) : filteredPlaylists.length === 0 ? (
        <Card>
          <p class="font-body text-[15px] leading-relaxed text-[#AAB6C6]">No playlists match the current filters.</p>
        </Card>
      ) : (
        <>
          <div id="playlists-grid" class="mt-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
            {visibleLibraryPlaylists.map((playlist) => (
              <article class="group rounded-2xl border border-white/10 bg-[#11151C]/60 overflow-hidden hover:border-[#5CC8FF]/40 transition duration-150 ease-out">
                <a href={buildUrl({ playlist: playlist.id })} class="block" aria-label={`Open ${playlist.title}`}>
                  <div class="relative aspect-square w-full bg-[#1A2230] bg-cover bg-center" style={`background-image:url('${fallbackCoverUrl}')`}>
                    {playlist.artwork_url ? (
                      <img
                        src={playlist.artwork_url}
                        alt={playlist.title}
                        loading="lazy"
                        decoding="async"
                        onerror="this.style.display='none'"
                        class="h-full w-full object-cover opacity-95 group-hover:opacity-100 transition duration-150 ease-out"
                      />
                    ) : null}
                    <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/25 opacity-0 transition duration-150 ease-out group-hover:opacity-100">
                      <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#0A0C10]/70 text-[#E7EDF6]">
                        →
                      </span>
                    </div>
                  </div>
                </a>
                <div class="p-3">
                  <p class="text-sm font-semibold tracking-tight text-[#E7EDF6]">{playlist.title}</p>
                  {playlist.genre && <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[#77849A]">{playlist.genre}</p>}
                </div>
              </article>
            ))}
          </div>
          {paginationEnabled ? (
            totalPages > 1 && (
              <div class="mt-6 flex items-center justify-between gap-3 rounded-2xl border border-white/10 bg-[#11151C]/70 p-3">
                <a
                  href={buildUrl({ page: currentPage - 1 })}
                  class:list={[
                    "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                    currentPage <= 1
                      ? "pointer-events-none border-white/10 text-[#77849A]"
                      : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
                  ]}
                >
                  Previous
                </a>
                <p class="text-xs uppercase tracking-[0.12em] text-[#AAB6C6]">
                  Page {currentPage} / {totalPages}
                </p>
                <a
                  href={buildUrl({ page: currentPage + 1 })}
                  class:list={[
                    "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                    currentPage >= totalPages
                      ? "pointer-events-none border-white/10 text-[#77849A]"
                      : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
                  ]}
                >
                  Next
                </a>
              </div>
            )
          ) : (
            <>
              <script type="application/json" id="playlists-data">{clientPlaylistsJson}</script>
              <div id="playlists-infinite-sentinel" class="mt-6 text-center text-[11px] font-semibold uppercase tracking-[0.16em] text-[#77849A]">
                Loading more playlists
              </div>
            </>
          )}
        </>
      )}
    </div>
  </Section>
</BaseLayout>

<script is:inline>
  (() => {
    const filterForm = document.querySelector("[data-playlist-filter-form]");
    if (!(filterForm instanceof HTMLFormElement)) return;

    const genreSelect = filterForm.querySelector("#playlist-filter-genre");
    if (!(genreSelect instanceof HTMLSelectElement)) return;

    genreSelect.addEventListener("change", () => {
      const params = new URLSearchParams();
      for (const [key, value] of new FormData(filterForm).entries()) {
        if (typeof value === "string" && value) {
          params.set(key, value);
        }
      }
      params.delete("page");
      params.delete("playlist");
      const query = params.toString();
      const target = query ? `/playlists?${query}` : "/playlists";
      const current = `${window.location.pathname}${window.location.search}`;
      if (target !== current) {
        window.location.assign(target);
      }
    });
  })();
</script>

{paginationEnabled ? (
  <script type="module" is:inline>
    import { navigate } from "astro:transitions/client";

    (() => {
      const form = document.querySelector("[data-live-search-form]");
      const input = form?.querySelector("#playlist-search");
      if (!(input instanceof HTMLInputElement)) return;

      let timer;

      const navigateToSearch = () => {
        const q = input.value.trim();
        const url = new URL(window.location.href);

        if (q) url.searchParams.set("q", q);
        else url.searchParams.delete("q");
        url.searchParams.delete("page");
        url.searchParams.delete("playlist");

        const target = `${url.pathname}${url.search}`;
        const current = `${window.location.pathname}${window.location.search}`;
        if (target !== current) {
          navigate(target);
        }
      };

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        window.clearTimeout(timer);
        navigateToSearch();
      });

      input.addEventListener("input", () => {
        window.clearTimeout(timer);
        timer = window.setTimeout(navigateToSearch, 220);
      });

      input.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          window.clearTimeout(timer);
          navigateToSearch();
        }
      });
    })();
  </script>
) : (
  <script is:inline>
    (() => {
      const form = document.querySelector("[data-live-search-form]");
      const input = form?.querySelector("#playlist-search");
      let timer;

      const grid = document.getElementById("playlists-grid");
      const dataNode = document.getElementById("playlists-data");
      const sentinel = document.getElementById("playlists-infinite-sentinel");

      if (input instanceof HTMLInputElement && grid instanceof HTMLElement && dataNode instanceof HTMLScriptElement && sentinel instanceof HTMLElement) {
        const allPlaylists = JSON.parse(dataNode.textContent || "[]");
        const initialCount = 24;
        const pageSize = 12;
        let visibleCount = Math.min(initialCount, allPlaylists.length);
        let activeList = allPlaylists;

        const escapeHtml = (value) =>
          String(value)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");

        const cardHtml = (playlist) => `
          <article class="group rounded-2xl border border-white/10 bg-[#11151C]/60 overflow-hidden hover:border-[#5CC8FF]/40 transition duration-150 ease-out">
            <a href="${escapeHtml(buildPlaylistHref(playlist.id))}" class="block" aria-label="Open ${escapeHtml(playlist.title)}">
              <div class="relative aspect-square w-full bg-[#1A2230] bg-cover bg-center" style="background-image:url('/textures/bg-main.png')">
                ${
                  playlist.artwork_url
                    ? `<img src="${escapeHtml(playlist.artwork_url)}" alt="${escapeHtml(playlist.title)}" loading="lazy" decoding="async" onerror="this.style.display='none'" class="h-full w-full object-cover opacity-95 group-hover:opacity-100 transition duration-150 ease-out" />`
                    : ""
                }
                <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/25 opacity-0 transition duration-150 ease-out group-hover:opacity-100">
                  <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#0A0C10]/70 text-[#E7EDF6]">→</span>
                </div>
              </div>
            </a>
            <div class="p-3">
              <p class="text-sm font-semibold tracking-tight text-[#E7EDF6]">${escapeHtml(playlist.title)}</p>
              ${playlist.genre ? `<p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[#77849A]">${escapeHtml(playlist.genre)}</p>` : ""}
            </div>
          </article>
        `;

        const toggleSentinel = () => {
          sentinel.classList.toggle("hidden", visibleCount >= activeList.length || activeList.length === 0);
        };

        const buildPlaylistHref = (playlistId) => {
          const url = new URL(window.location.href);
          url.searchParams.set("playlist", String(playlistId));
          return `${url.pathname}${url.search}`;
        };

        const render = () => {
          const q = input.value.trim().toLowerCase();
          activeList = q ? allPlaylists.filter((playlist) => String(playlist.title || "").toLowerCase().includes(q)) : allPlaylists;
          visibleCount = Math.min(Math.max(pageSize, visibleCount), activeList.length);
          const items = activeList.slice(0, visibleCount);

          if (items.length === 0) {
            grid.innerHTML = `<div class="col-span-full rounded-2xl border border-white/10 bg-[#11151C]/70 p-5 sm:p-6"><p class="font-body text-[15px] leading-relaxed text-[#AAB6C6]">No playlists match the current filters.</p></div>`;
          } else {
            grid.innerHTML = items.map(cardHtml).join("");
          }
          toggleSentinel();

          const url = new URL(window.location.href);
          if (q) url.searchParams.set("q", input.value.trim());
          else url.searchParams.delete("q");
          window.history.replaceState({}, "", `${url.pathname}${url.search}`);
        };

        const fillViewport = () => {
          while (visibleCount < activeList.length && document.documentElement.scrollHeight <= window.innerHeight + 160) {
            visibleCount = Math.min(activeList.length, visibleCount + pageSize);
            render();
          }
        };

        form?.addEventListener("submit", (event) => {
          event.preventDefault();
          window.clearTimeout(timer);
          visibleCount = Math.min(pageSize, activeList.length || allPlaylists.length);
          render();
        });

        input.addEventListener("input", () => {
          window.clearTimeout(timer);
          timer = window.setTimeout(() => {
            visibleCount = Math.min(pageSize, allPlaylists.length);
            render();
          }, 160);
        });

        const observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting || visibleCount >= activeList.length) return;
            visibleCount = Math.min(activeList.length, visibleCount + pageSize);
            render();
            fillViewport();
          },
          { rootMargin: "260px 0px" },
        );

        observer.observe(sentinel);
        render();
        fillViewport();
        window.addEventListener("resize", fillViewport);
      }
    })();
  </script>
)}
