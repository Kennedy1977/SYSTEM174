---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import ButtonPrimary from "../../components/ButtonPrimary.astro";
---

<BaseLayout
  title="System 174 | SoundCloud Token Export"
  description="Temporary admin utility for exporting the current SoundCloud OAuth token pair."
  robots="noindex,nofollow"
>
  <Section
    title="TOKEN EXPORT"
    description="Temporary admin utility. Set SOUNDCLOUD_TOKEN_EXPORT_KEY on the server, enter it here, copy the current tokens into your persistent env, then remove the export key again."
    headingLevel={1}
  >
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <Card>
          <form id="token-export-form" class="space-y-4">
            <label class="block">
              <span class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Export Key</span>
              <input
                id="token-export-key"
                type="password"
                autocomplete="current-password"
                placeholder="Temporary server-side export key"
                class="mt-2 w-full rounded-xl bg-[#0A0C10]/40 border border-white/10 px-3 py-2 text-sm text-[#E7EDF6] placeholder:text-[#77849A] focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/50 focus:border-[#5CC8FF]/50"
              />
              <p class="mt-2 text-xs text-[#77849A]">
                This must match the deployed <code>SOUNDCLOUD_TOKEN_EXPORT_KEY</code> value.
              </p>
            </label>

            <div class="flex flex-wrap gap-3">
              <ButtonPrimary type="submit">REVEAL TOKENS</ButtonPrimary>
              <button
                id="copy-refresh-token"
                type="button"
                disabled
                class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border border-white/15 text-[#E7EDF6] hover:border-white/30 hover:bg-white/5 focus:outline-none focus:ring-2 focus:ring-white/20 focus:ring-offset-2 focus:ring-offset-[#0A0C10] transition duration-150 ease-out disabled:cursor-not-allowed disabled:opacity-40"
              >
                COPY REFRESH TOKEN
              </button>
            </div>
          </form>
        </Card>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Use Once</p>
          <p class="mt-3 text-sm leading-relaxed text-[#AAB6C6]">
            After you copy the current token pair into your host env, delete <code>SOUNDCLOUD_TOKEN_EXPORT_KEY</code> from the server and redeploy or restart the app.
          </p>
        </Card>
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Next Step</p>
          <p class="mt-3 text-sm leading-relaxed text-[#AAB6C6]">
            Update <code>SOUNDCLOUD_ACCESS_TOKEN</code> and <code>SOUNDCLOUD_REFRESH_TOKEN</code> in your persistent env with the values shown below.
          </p>
        </Card>
      </div>

      <div class="lg:col-span-12">
        <Card>
          <p id="token-export-status" class="text-sm text-[#AAB6C6]">
            Enter the export key to fetch the current SoundCloud token pair from the live server.
          </p>
          <pre
            id="token-export-result"
            class="mt-4 overflow-x-auto rounded-xl border border-white/10 bg-[#0A0C10]/60 p-4 text-xs leading-relaxed text-[#E7EDF6]"
          >Awaiting request...</pre>
        </Card>
      </div>
    </div>
  </Section>

  <script is:inline>
    (() => {
      const form = document.getElementById("token-export-form");
      const keyInput = document.getElementById("token-export-key");
      const statusEl = document.getElementById("token-export-status");
      const resultEl = document.getElementById("token-export-result");
      const copyButton = document.getElementById("copy-refresh-token");
      let refreshToken = "";

      const setStatus = (message) => {
        if (statusEl) {
          statusEl.textContent = message;
        }
      };

      const setResult = (message) => {
        if (resultEl) {
          resultEl.textContent = message;
        }
      };

      const setCopyEnabled = (enabled) => {
        if (copyButton instanceof HTMLButtonElement) {
          copyButton.disabled = !enabled;
        }
      };

      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const key = keyInput instanceof HTMLInputElement ? keyInput.value.trim() : "";
        refreshToken = "";
        setCopyEnabled(false);

        if (!key) {
          setStatus("Enter the export key first.");
          setResult("Awaiting request...");
          return;
        }

        setStatus("Requesting current SoundCloud tokens...");
        setResult("Loading...");

        try {
          const response = await fetch("/api/soundcloud/token-export", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            cache: "no-store",
            body: JSON.stringify({ key }),
          });

          const raw = await response.text();
          let payload = { error: raw || "Unexpected response" };

          try {
            payload = JSON.parse(raw);
          } catch {
            // Fall back to the raw text payload above.
          }

          if (!response.ok) {
            setStatus(payload.error || `Request failed (${response.status}).`);
            setResult(JSON.stringify(payload, null, 2));
            return;
          }

          refreshToken =
            typeof payload.SOUNDCLOUD_REFRESH_TOKEN === "string" ? payload.SOUNDCLOUD_REFRESH_TOKEN : "";

          setCopyEnabled(Boolean(refreshToken));
          setStatus("Tokens loaded. Copy the refresh token into your env, then remove the export key.");
          setResult(JSON.stringify(payload, null, 2));
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error);
          setStatus("Token export request failed.");
          setResult(JSON.stringify({ error: message }, null, 2));
        }
      });

      copyButton?.addEventListener("click", async () => {
        if (!refreshToken) {
          return;
        }

        try {
          await navigator.clipboard.writeText(refreshToken);
          setStatus("Refresh token copied. Remove SOUNDCLOUD_TOKEN_EXPORT_KEY after updating your env.");
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error);
          setStatus(`Unable to copy the refresh token: ${message}`);
        }
      });
    })();
  </script>
</BaseLayout>
