---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";
import ButtonPrimary from "../../components/ButtonPrimary.astro";
---

<BaseLayout
  title="System 174 | SoundCloud Status"
  description="Temporary admin utility for checking live SoundCloud connection health."
  robots="noindex,nofollow"
>
  <Section
    title="SOUNDCLOUD STATUS"
    description="Temporary admin utility. Set SOUNDCLOUD_TOKEN_EXPORT_KEY on the server, enter it here, and check whether the live SoundCloud configuration, tokens, and API requests are healthy."
  >
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <Card>
          <form id="soundcloud-status-form" class="space-y-4">
            <label class="block">
              <span class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Admin Key</span>
              <input
                id="soundcloud-status-key"
                type="password"
                autocomplete="current-password"
                placeholder="Temporary server-side export key"
                class="mt-2 w-full rounded-xl bg-[#0A0C10]/40 border border-white/10 px-3 py-2 text-sm text-[#E7EDF6] placeholder:text-[#77849A] focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/50 focus:border-[#5CC8FF]/50"
              />
              <p class="mt-2 text-xs text-[#77849A]">
                This uses the deployed <code>SOUNDCLOUD_TOKEN_EXPORT_KEY</code> value, but it does not expose raw token values.
              </p>
            </label>

            <div class="flex flex-wrap gap-3">
              <ButtonPrimary type="submit">CHECK STATUS</ButtonPrimary>
            </div>
          </form>
        </Card>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Checks</p>
          <p class="mt-3 text-sm leading-relaxed text-[#AAB6C6]">
            This reports whether the live server has SoundCloud OAuth config, whether it has tokens,
            and whether real requests to SoundCloud are still working.
          </p>
        </Card>
        <Card>
          <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">Safe Output</p>
          <p class="mt-3 text-sm leading-relaxed text-[#AAB6C6]">
            Status details only. No access token or refresh token is returned by this page.
          </p>
        </Card>
      </div>

      <div class="lg:col-span-12">
        <Card>
          <p id="soundcloud-status-summary" class="text-sm text-[#AAB6C6]">
            Enter the admin key to check the current SoundCloud status on the live server.
          </p>
          <pre
            id="soundcloud-status-result"
            class="mt-4 overflow-x-auto rounded-xl border border-white/10 bg-[#0A0C10]/60 p-4 text-xs leading-relaxed text-[#E7EDF6]"
          >Awaiting request...</pre>
        </Card>
      </div>
    </div>
  </Section>

  <script is:inline>
    (() => {
      const form = document.getElementById("soundcloud-status-form");
      const keyInput = document.getElementById("soundcloud-status-key");
      const summaryEl = document.getElementById("soundcloud-status-summary");
      const resultEl = document.getElementById("soundcloud-status-result");

      const setSummary = (message) => {
        if (summaryEl) {
          summaryEl.textContent = message;
        }
      };

      const setResult = (message) => {
        if (resultEl) {
          resultEl.textContent = message;
        }
      };

      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const key = keyInput instanceof HTMLInputElement ? keyInput.value.trim() : "";

        if (!key) {
          setSummary("Enter the admin key first.");
          setResult("Awaiting request...");
          return;
        }

        setSummary("Checking live SoundCloud status...");
        setResult("Loading...");

        try {
          const response = await fetch("/api/soundcloud/status", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            cache: "no-store",
            body: JSON.stringify({ key }),
          });

          const raw = await response.text();
          let payload = { error: raw || "Unexpected response" };

          try {
            payload = JSON.parse(raw);
          } catch {
            // Fall back to the raw text payload above.
          }

          if (!response.ok) {
            setSummary(payload.error || `Request failed (${response.status}).`);
            setResult(JSON.stringify(payload, null, 2));
            return;
          }

          setSummary(typeof payload.message === "string" ? payload.message : "Status loaded.");
          setResult(JSON.stringify(payload, null, 2));
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error);
          setSummary("SoundCloud status request failed.");
          setResult(JSON.stringify({ error: message }, null, 2));
        }
      });
    })();
  </script>
</BaseLayout>
