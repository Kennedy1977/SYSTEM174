---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import SoundCloudTrackCard from "../components/SoundCloudTrackCard.astro";
import { getSoundCloudDashboardData } from "../lib/soundcloud";
import { getSoundCloudPlayerUrl } from "../lib/soundcloud-embed";
import { isSoundCloudPaginationEnabled } from "../lib/site-config";

const soundcloud = await getSoundCloudDashboardData();
const tracks = soundcloud.tracks;
const playlists = soundcloud.playlists;
const selectedGenre = (Astro.url.searchParams.get("genre") ?? "").trim();
const selectedGenreKey = selectedGenre.toLowerCase();
const remixParam = (Astro.url.searchParams.get("remix") ?? "off").trim().toLowerCase();
const showRemix = remixParam === "on";
const sortParam = (Astro.url.searchParams.get("sort") ?? "newest").trim().toLowerCase();
const sortBy = sortParam === "plays" || sortParam === "likes" ? sortParam : "newest";
const trackSearch = (Astro.url.searchParams.get("q") ?? "").trim();
const trackSearchKey = trackSearch.toLowerCase();
const paginationEnabled = isSoundCloudPaginationEnabled();
const TRACKS_BATCH_SIZE = 8;
const rawPage = Number(Astro.url.searchParams.get("page") ?? "1");
const requestedPage = Number.isFinite(rawPage) ? Math.max(1, Math.floor(rawPage)) : 1;

const isCoverOrBootleg = (item: { title: string }) => {
  const title = item.title.toLowerCase();
  return title.includes("cover") || title.includes("bootleg");
};

const isPrivateTrack = (item: { sharing?: string | null }) => (item.sharing ?? "").toLowerCase() === "private";
const isBlockedByAccess = (item: { access?: string | null }) =>
  (item.access ?? "")
    .toLowerCase()
    .split(",")
    .map((part) => part.trim())
    .includes("blocked");

const hasTrackWord = (item: { title: string }) => item.title.toLowerCase().includes("track");

const isRemixTrack = (item: { title: string }) => item.title.toLowerCase().includes("remix");

const curatedTracks = tracks.filter(
  (track) =>
    !isPrivateTrack(track) &&
    !isBlockedByAccess(track) &&
    !isCoverOrBootleg(track) &&
    !hasTrackWord(track),
);
const remixFilteredTracks = curatedTracks.filter((track) => (showRemix ? isRemixTrack(track) : !isRemixTrack(track)));

const allGenres = Array.from(
  new Set(
    [...tracks, ...playlists]
      .map((item) => (item.genre ?? "").trim())
      .filter(Boolean),
  ),
).sort((a, b) => a.localeCompare(b));

const filteredTracks = selectedGenre
  ? remixFilteredTracks.filter((track) => (track.genre ?? "").trim().toLowerCase() === selectedGenreKey)
  : remixFilteredTracks;

const sortedTracks = [...filteredTracks].sort((a, b) => {
  if (sortBy === "plays") {
    return (b.playback_count ?? 0) - (a.playback_count ?? 0);
  }
  if (sortBy === "likes") {
    return (b.favoritings_count ?? 0) - (a.favoritings_count ?? 0);
  }
  return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
});

const searchedTracks = trackSearchKey
  ? sortedTracks.filter((track) => track.title.toLowerCase().includes(trackSearchKey))
  : sortedTracks;

const totalTrackPages = Math.max(1, Math.ceil(searchedTracks.length / TRACKS_BATCH_SIZE));
const currentTrackPage = Math.min(requestedPage, totalTrackPages);
const trackStartIndex = (currentTrackPage - 1) * TRACKS_BATCH_SIZE;

const buildMusicUrl = (overrides?: {
  genre?: string | null;
  remix?: boolean;
  sort?: "newest" | "plays" | "likes";
  q?: string | null;
  page?: number | null;
}) => {
  const params = new URLSearchParams();
  const genre = overrides?.genre === undefined ? selectedGenre : overrides.genre ?? "";
  const remix = overrides?.remix === undefined ? showRemix : overrides.remix;
  const sort = overrides?.sort === undefined ? sortBy : overrides.sort;
  const q = overrides?.q === undefined ? trackSearch : overrides.q ?? "";
  const page = overrides?.page === undefined ? (paginationEnabled ? currentTrackPage : null) : overrides.page;

  if (genre) params.set("genre", genre);
  if (remix) params.set("remix", "on");
  if (sort && sort !== "newest") params.set("sort", sort);
  if (q) params.set("q", q);
  if (paginationEnabled && page && page > 1) params.set("page", String(page));

  const query = params.toString();
  return query ? `/music?${query}` : "/music";
};

const genreFilters = [
  { label: "All", href: buildMusicUrl({ genre: null, page: null }), active: !selectedGenre },
  ...allGenres.map((genre) => ({
    label: genre,
    href: buildMusicUrl({ genre, page: null }),
    active: genre.toLowerCase() === selectedGenreKey,
  })),
];

const fallbackCoverUrl = "/textures/bg-main.png";
const toTrackCard = (track: (typeof searchedTracks)[number]) => ({
  title: track.title,
  genre: track.genre ?? "",
  artworkUrl: track.artwork_url ?? "",
  sourceUrl: track.permalink_url,
  playUrl: getSoundCloudPlayerUrl(track.permalink_url),
  pauseUrl: getSoundCloudPlayerUrl(track.permalink_url, false),
  href: track.permalink_url,
});
const clientTracks = searchedTracks.map((track) => toTrackCard(track));
const initialTracks = clientTracks.slice(0, TRACKS_BATCH_SIZE);
const paginatedTracks = searchedTracks.slice(trackStartIndex, trackStartIndex + TRACKS_BATCH_SIZE).map((track) => toTrackCard(track));
const visibleTracks = paginationEnabled ? paginatedTracks : initialTracks;
const clientTracksJson = JSON.stringify(clientTracks).replaceAll("<", "\\u003c");
---

<BaseLayout title="System 174 | Music">
  <Section title="MUSIC" description="Tracks are synced from your connected SoundCloud account.">
    <div class="mb-10 rounded-2xl border border-white/10 bg-[#11151C]/70 p-5 sm:p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="label-ui">Genre</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {genreFilters.map((filter) => (
              <a
                href={filter.href}
                class:list={[
                  "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                  filter.active
                    ? "border-[#5CC8FF]/70 bg-[#5CC8FF]/10 text-[#E7EDF6] shadow-[0_0_0_1px_rgba(92,200,255,0.25)]"
                    : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
                ]}
                aria-current={filter.active ? "true" : undefined}
              >
                {filter.label}
              </a>
            ))}
          </div>
        </div>
        <div class="sm:text-right">
          <p class="label-ui">Track Filter</p>
          <div class="mt-3 flex flex-wrap justify-start gap-2 sm:justify-end">
            <a
              href={buildMusicUrl({ remix: !showRemix, page: null })}
              class:list={[
                "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                showRemix
                  ? "border-[#5CC8FF]/70 bg-[#5CC8FF]/10 text-[#E7EDF6] shadow-[0_0_0_1px_rgba(92,200,255,0.25)]"
                  : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
              ]}
            >
              Remix {showRemix ? "On" : "Off"}
            </a>
          </div>
          <div class="mt-2 flex flex-wrap justify-start gap-2 sm:justify-end">
            <a
              href={buildMusicUrl({ sort: "newest", page: null })}
              class:list={[
                "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                sortBy === "newest"
                  ? "border-[#5CC8FF]/70 bg-[#5CC8FF]/10 text-[#E7EDF6] shadow-[0_0_0_1px_rgba(92,200,255,0.25)]"
                  : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
              ]}
            >
              Newest
            </a>
            <a
              href={buildMusicUrl({ sort: "plays", page: null })}
              class:list={[
                "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                sortBy === "plays"
                  ? "border-[#5CC8FF]/70 bg-[#5CC8FF]/10 text-[#E7EDF6] shadow-[0_0_0_1px_rgba(92,200,255,0.25)]"
                  : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
              ]}
            >
              Most Plays
            </a>
            <a
              href={buildMusicUrl({ sort: "likes", page: null })}
              class:list={[
                "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                sortBy === "likes"
                  ? "border-[#5CC8FF]/70 bg-[#5CC8FF]/10 text-[#E7EDF6] shadow-[0_0_0_1px_rgba(92,200,255,0.25)]"
                  : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
              ]}
            >
              Most Likes
            </a>
          </div>
          <p class="mt-2 text-[11px] uppercase tracking-[0.12em] text-[#77849A]">Cover and Bootleg are always hidden</p>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <h3 class="font-display text-xl md:text-2xl tracking-[-0.01em] uppercase">Tracks</h3>
        <form method="get" action="/music" class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row" data-live-search-form>
          <input
            type="search"
            name="q"
            id="track-search"
            value={trackSearch}
            placeholder="Search tracks"
            class="w-full rounded-xl bg-[#0A0C10]/40 border border-white/10 px-3 py-2 text-sm text-[#E7EDF6] placeholder:text-[#77849A] focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/50 focus:border-[#5CC8FF]/50 sm:w-64"
          />
          {selectedGenre && <input type="hidden" name="genre" value={selectedGenre} />}
          {showRemix && <input type="hidden" name="remix" value="on" />}
          {sortBy !== "newest" && <input type="hidden" name="sort" value={sortBy} />}
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold bg-[#1A2230] border border-white/10 text-[#E7EDF6] hover:bg-[#1A2230]/80 hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/40 focus:ring-offset-2 focus:ring-offset-[#0A0C10] transition duration-150 ease-out"
          >
            Search
          </button>
          {trackSearch && (
            <a
              href={buildMusicUrl({ q: null, page: null })}
              class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border border-white/10 text-[#AAB6C6] hover:text-[#E7EDF6] hover:border-white/20 transition duration-150 ease-out"
            >
              Clear
            </a>
          )}
        </form>
      </div>
      {searchedTracks.length === 0 ? (
        <Card>
          <p class="font-body text-[15px] leading-relaxed text-[#AAB6C6]">
            No tracks match the current genre, remix, and search filters.
          </p>
        </Card>
      ) : (
        <>
          <div id="music-grid" class="mt-4 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
            {visibleTracks.map((track) => (
              <SoundCloudTrackCard
                title={track.title}
                genre={track.genre}
                artworkUrl={track.artworkUrl}
                fallbackCoverUrl={fallbackCoverUrl}
                sourceUrl={track.sourceUrl}
                playUrl={track.playUrl}
                pauseUrl={track.pauseUrl}
                trackHref={track.href}
              />
            ))}
          </div>
          {paginationEnabled ? (
            totalTrackPages > 1 && (
              <div class="mt-6 flex items-center justify-between gap-3 rounded-2xl border border-white/10 bg-[#11151C]/70 p-3">
                <a
                  href={buildMusicUrl({ page: currentTrackPage - 1 })}
                  class:list={[
                    "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                    currentTrackPage <= 1
                      ? "pointer-events-none border-white/10 text-[#77849A]"
                      : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
                  ]}
                >
                  Previous
                </a>
                <p class="text-xs uppercase tracking-[0.12em] text-[#AAB6C6]">
                  Page {currentTrackPage} / {totalTrackPages}
                </p>
                <a
                  href={buildMusicUrl({ page: currentTrackPage + 1 })}
                  class:list={[
                    "inline-flex items-center justify-center rounded-xl border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] transition duration-150 ease-out",
                    currentTrackPage >= totalTrackPages
                      ? "pointer-events-none border-white/10 text-[#77849A]"
                      : "border-white/10 bg-[#1A2230] text-[#AAB6C6] hover:border-[#5CC8FF]/40 hover:text-[#E7EDF6]",
                  ]}
                >
                  Next
                </a>
              </div>
            )
          ) : (
            <>
              <script type="application/json" id="music-data">{clientTracksJson}</script>
              <div id="music-infinite-sentinel" class="mt-6 text-center text-[11px] font-semibold uppercase tracking-[0.16em] text-[#77849A]">
                Loading more tracks
              </div>
            </>
          )}
        </>
      )}
    </div>

  </Section>
</BaseLayout>

<script type="module" is:inline>
  import { navigate } from "astro:transitions/client";

  (() => {
    const form = document.querySelector("[data-live-search-form]");
    if (!form) return;

    const input = form.querySelector("#track-search");
    if (!(input instanceof HTMLInputElement)) return;

    let timer;

    const navigateToSearch = () => {
      const q = input.value.trim();
      const url = new URL(window.location.href);

      if (q) url.searchParams.set("q", q);
      else url.searchParams.delete("q");
      url.searchParams.delete("page");

      const target = `${url.pathname}${url.search}`;
      const current = `${window.location.pathname}${window.location.search}`;
      if (target !== current) {
        navigate(target);
      }
    };

    input.addEventListener("input", () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(navigateToSearch, 220);
    });

    input.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        window.clearTimeout(timer);
        navigateToSearch();
      }
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      window.clearTimeout(timer);
      navigateToSearch();
    });

    const grid = document.getElementById("music-grid");
    const dataNode = document.getElementById("music-data");
    const sentinel = document.getElementById("music-infinite-sentinel");

    if (grid instanceof HTMLElement && dataNode instanceof HTMLScriptElement && sentinel instanceof HTMLElement) {
      const allTracks = JSON.parse(dataNode.textContent || "[]");
      const batchSize = 8;
      let visibleCount = Math.min(batchSize, allTracks.length);

      const escapeHtml = (value) =>
        String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const cardHtml = (track) => `
        <article class="group rounded-2xl border border-white/10 bg-[#11151C]/60 overflow-hidden hover:border-[#5CC8FF]/40 transition duration-150 ease-out">
          <button
            type="button"
            data-sc-source="${escapeHtml(track.sourceUrl || track.href || "")}"
            data-sc-play="${escapeHtml(track.playUrl || "")}"
            data-sc-pause="${escapeHtml(track.pauseUrl || "")}"
            data-sc-title="${escapeHtml(track.title || "")}"
            data-sc-artwork="${escapeHtml(track.artworkUrl || "")}"
            data-sc-href="${escapeHtml(track.href || "")}"
            class="block w-full text-left"
            aria-label="Play ${escapeHtml(track.title || "track")}"
          >
            <div class="relative aspect-square w-full bg-[#1A2230] bg-cover bg-center" style="background-image:url('/textures/bg-main.png')">
              ${
                track.artworkUrl
                  ? `<img src="${escapeHtml(track.artworkUrl)}" alt="${escapeHtml(track.title || "")}" loading="lazy" decoding="async" onerror="this.style.display='none'" class="h-full w-full object-cover opacity-95 group-hover:opacity-100 transition duration-150 ease-out" />`
                  : ""
              }
              <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/25 opacity-0 transition duration-150 ease-out group-hover:opacity-100">
                <span data-icon-toggle class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#0A0C10]/70 text-[#E7EDF6]">▶</span>
              </div>
            </div>
          </button>
          <div class="p-3">
            <p class="text-sm font-semibold tracking-tight text-[#E7EDF6]">${escapeHtml(track.title || "")}</p>
            ${track.genre ? `<p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[#77849A]">${escapeHtml(track.genre)}</p>` : ""}
          </div>
        </article>
      `;

      const render = () => {
        grid.innerHTML = allTracks.slice(0, visibleCount).map(cardHtml).join("");
        sentinel.classList.toggle("hidden", visibleCount >= allTracks.length);
      };

      render();

      if (visibleCount < allTracks.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;
            visibleCount = Math.min(allTracks.length, visibleCount + batchSize);
            render();
            if (visibleCount >= allTracks.length) {
              observer.disconnect();
            }
          },
          { rootMargin: "260px 0px" },
        );

        observer.observe(sentinel);
      }
    }
  })();
</script>
