---
const { release, featured = false } = Astro.props;
---

<article class:list={[
  "group rounded-2xl border border-white/10 bg-[#11151C]/60 overflow-hidden hover:border-[#B8FF2C]/40 transition duration-150 ease-out",
  featured && "md:grid md:grid-cols-12 md:items-stretch",
]}>
  <div class:list={["aspect-square w-full object-cover opacity-95 group-hover:opacity-100 transition duration-150 ease-out bg-[#1A2230]", featured && "md:col-span-4 md:aspect-auto"]}></div>
  <div class:list={["p-3", featured && "md:col-span-8 md:p-6"]}>
    <p class="text-sm font-semibold tracking-tight">{release.title}</p>
    <p class="mt-1 text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">{release.type} {release.year}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {release.links.map((label: string) => (
        <a href="#" class="text-xs text-[#AAB6C6] hover:text-[#E7EDF6] transition duration-150 ease-out">{label}</a>
      ))}
    </div>
  </div>
</article>
