---
const { status } = Astro.props;
---

{status === "LOW_TICKETS" && (
  <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold bg-[#5CC8FF]/10 text-[#5CC8FF] border border-[#5CC8FF]/30">
    LOW TICKETS
  </span>
)}
{status === "SOLD_OUT" && (
  <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold bg-transparent text-[#77849A] border border-white/10">
    SOLD OUT
  </span>
)}
{status === "NEW" && (
  <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold bg-[#5CC8FF]/10 text-[#5CC8FF] border border-[#5CC8FF]/30">
    NEW
  </span>
)}
