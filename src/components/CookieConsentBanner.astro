---
const cookiePolicyHref = "/cookies";
---

<div
  id="cookie-consent-root"
  class="pointer-events-none fixed inset-x-0 top-0 z-[80] px-3 sm:px-5"
  style="padding-top: max(0.75rem, env(safe-area-inset-top));"
>
  <section
    id="cookie-consent-banner"
    role="dialog"
    aria-labelledby="cookie-consent-title"
    aria-describedby="cookie-consent-description"
    aria-live="polite"
    aria-hidden="true"
    class="pointer-events-auto mx-auto w-full max-w-5xl rounded-[1.75rem] border border-[#5CC8FF]/20 bg-[#0F131A]/95 opacity-0 shadow-[0_28px_80px_-30px_rgba(0,0,0,0.95)] backdrop-blur-xl transition duration-300 ease-out -translate-y-4"
    data-visible="false"
  >
    <div class="h-px w-full bg-gradient-to-r from-transparent via-[#5CC8FF]/70 to-transparent"></div>
    <div class="p-4 sm:p-5 lg:p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-3xl">
          <p class="label-ui">Privacy Controls</p>
          <h2
            id="cookie-consent-title"
            tabindex="-1"
            class="mt-3 font-display text-2xl tracking-[-0.015em] uppercase text-white"
          >
            Analytics stays off until you say yes.
          </h2>
          <p
            id="cookie-consent-description"
            class="mt-3 font-body text-[15px] leading-relaxed text-[#AAB6C6]"
          >
            We use one essential cookie to remember your choice and optional Google Analytics
            cookies to understand site traffic. Reject keeps analytics off. You can review the
            details in our
            <a
              href={cookiePolicyHref}
              class="text-accent underline decoration-[#5CC8FF]/40 underline-offset-4 transition hover:text-white"
            >
              cookie notice
            </a>
            and change your choice at any time.
          </p>
        </div>

        <div class="flex flex-wrap gap-2 lg:max-w-[22rem] lg:justify-end">
          <button
            type="button"
            data-consent-action="manage"
            aria-controls="cookie-consent-panel"
            aria-expanded="false"
            class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/5 px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E7EDF6] transition hover:border-white/30 hover:bg-white/10"
          >
            Manage settings
          </button>
          <button
            type="button"
            data-consent-action="reject"
            class="inline-flex items-center justify-center rounded-full border border-white/18 bg-[#0A0C10] px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white transition hover:border-white/40 hover:bg-white/6"
          >
            Reject analytics
          </button>
          <button
            type="button"
            data-consent-action="accept"
            class="inline-flex items-center justify-center rounded-full border border-[#5CC8FF]/60 bg-[#5CC8FF] px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#0A0C10] transition hover:border-[#8BD9FF] hover:bg-[#8BD9FF]"
          >
            Accept analytics
          </button>
        </div>
      </div>

      <div
        id="cookie-consent-panel"
        class="mt-4 hidden rounded-2xl border border-white/10 bg-black/20 p-4 sm:p-5"
      >
        <div class="grid gap-4">
          <div class="grid gap-3 rounded-2xl border border-white/8 bg-white/[0.02] p-4 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <p class="label-ui">Required</p>
              <h3 class="mt-2 font-display text-lg tracking-[-0.01em] uppercase text-white">
                Necessary cookie
              </h3>
              <p class="mt-2 font-body text-[14px] leading-relaxed text-[#AAB6C6]">
                Stores your consent choice so the site can respect it on future visits.
              </p>
            </div>
            <span class="inline-flex items-center rounded-full border border-white/14 bg-white/6 px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E7EDF6]">
              Always active
            </span>
          </div>

          <div class="grid gap-3 rounded-2xl border border-white/8 bg-white/[0.02] p-4 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <p class="label-ui">Optional</p>
              <h3 class="mt-2 font-display text-lg tracking-[-0.01em] uppercase text-white">
                Google Analytics
              </h3>
              <p class="mt-2 font-body text-[14px] leading-relaxed text-[#AAB6C6]">
                Helps us understand visits, pages viewed, and traffic sources. It stays disabled
                unless you turn it on.
              </p>
            </div>
            <label class="inline-flex items-center gap-3 rounded-full border border-white/12 bg-white/5 px-4 py-3 text-sm text-[#E7EDF6]">
              <input
                id="cookie-consent-analytics"
                data-consent-role="analytics-toggle"
                type="checkbox"
                class="h-5 w-5 accent-[#5CC8FF]"
              />
              <span>Allow analytics cookies</span>
            </label>
          </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-2 sm:justify-end">
          <a
            href={cookiePolicyHref}
            class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/5 px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E7EDF6] transition hover:border-white/30 hover:bg-white/10"
          >
            Read cookie notice
          </a>
          <button
            type="button"
            data-consent-action="save"
            class="inline-flex items-center justify-center rounded-full border border-[#5CC8FF]/35 bg-[#15202D] px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E7EDF6] transition hover:border-[#5CC8FF]/60 hover:text-white"
          >
            Save choices
          </button>
        </div>
      </div>
    </div>
  </section>
</div>

<script is:inline>
  (() => {
    const store = window.__system174CookieBannerStore || (window.__system174CookieBannerStore = {
      forcedOpen: false,
      panelOpen: false,
      globalsBound: false,
      pageLoadBound: false,
    });

    const getManager = () => window.system174ConsentManager;
    const getConsentState = () =>
      getManager()?.getState?.() ?? { hasDecision: false, analytics: false, updatedAt: null };

    const getElements = () => {
      const banner = document.getElementById("cookie-consent-banner");
      return {
        banner,
        panel: document.getElementById("cookie-consent-panel"),
        title: document.getElementById("cookie-consent-title"),
        manageButton: banner?.querySelector('[data-consent-action="manage"]'),
        acceptButton: banner?.querySelector('[data-consent-action="accept"]'),
        rejectButton: banner?.querySelector('[data-consent-action="reject"]'),
        saveButton: banner?.querySelector('[data-consent-action="save"]'),
        analyticsToggle: banner?.querySelector('[data-consent-role="analytics-toggle"]'),
        settingsTriggers: document.querySelectorAll("[data-open-cookie-settings]"),
      };
    };

    const render = () => {
      const { banner, panel, manageButton, analyticsToggle } = getElements();
      if (!banner) return;

      const consentState = getConsentState();
      const shouldShow = store.forcedOpen || !consentState.hasDecision;
      const showPanel = shouldShow && store.panelOpen;

      banner.dataset.visible = shouldShow ? "true" : "false";
      banner.setAttribute("aria-hidden", shouldShow ? "false" : "true");
      banner.classList.toggle("opacity-0", !shouldShow);
      banner.classList.toggle("-translate-y-4", !shouldShow);
      banner.classList.toggle("pointer-events-none", !shouldShow);
      banner.classList.toggle("opacity-100", shouldShow);
      banner.classList.toggle("translate-y-0", shouldShow);

      if (!shouldShow) {
        store.panelOpen = false;
      }

      if (panel) {
        panel.classList.toggle("hidden", !showPanel);
      }

      if (manageButton) {
        manageButton.setAttribute("aria-expanded", showPanel ? "true" : "false");
      }

      if (analyticsToggle instanceof HTMLInputElement) {
        analyticsToggle.checked = consentState.analytics;
      }
    };

    const openSettings = () => {
      store.forcedOpen = true;
      store.panelOpen = true;
      render();

      requestAnimationFrame(() => {
        getElements().title?.focus();
      });
    };

    const saveConsent = (analyticsGranted) => {
      getManager()?.setAnalyticsConsent?.(analyticsGranted);
      store.forcedOpen = false;
      store.panelOpen = false;
      render();
    };

    const bindElementEvents = () => {
      const {
        banner,
        manageButton,
        acceptButton,
        rejectButton,
        saveButton,
        analyticsToggle,
        settingsTriggers,
      } = getElements();

      if (banner && banner.dataset.bound !== "true") {
        banner.dataset.bound = "true";

        manageButton?.addEventListener("click", () => {
          if (store.panelOpen) {
            store.panelOpen = false;
            if (getConsentState().hasDecision) {
              store.forcedOpen = false;
            }
          } else {
            store.forcedOpen = true;
            store.panelOpen = true;
          }
          render();
        });

        acceptButton?.addEventListener("click", () => {
          saveConsent(true);
        });

        rejectButton?.addEventListener("click", () => {
          saveConsent(false);
        });

        saveButton?.addEventListener("click", () => {
          const analyticsGranted =
            analyticsToggle instanceof HTMLInputElement ? analyticsToggle.checked : false;
          saveConsent(analyticsGranted);
        });
      }

      settingsTriggers.forEach((trigger) => {
        if (!(trigger instanceof HTMLElement) || trigger.dataset.cookieSettingsBound === "true") {
          return;
        }

        trigger.dataset.cookieSettingsBound = "true";
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          openSettings();
        });
      });
    };

    const init = () => {
      bindElementEvents();
      render();
    };

    window.__system174InitCookieBanner = init;

    if (!store.globalsBound) {
      window.addEventListener("system174:consent-updated", () => {
        if (getConsentState().hasDecision && !store.forcedOpen) {
          store.panelOpen = false;
        }
        render();
      });

      window.addEventListener("system174:open-cookie-settings", () => {
        openSettings();
      });

      store.globalsBound = true;
    }

    if (!store.pageLoadBound) {
      document.addEventListener("astro:page-load", () => {
        window.__system174InitCookieBanner?.();
      });
      store.pageLoadBound = true;
    }

    init();
  })();
</script>
