---
import { socials } from "../data/site";
---

<footer class="border-t border-white/10">
  <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8 py-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-xs font-mono uppercase tracking-[0.2em] text-[#77849A]">© 2026 System 174</p>
    <div class="flex items-center gap-4">
      {socials.map((social) => (
        <a href={social.href} class="text-sm text-[#AAB6C6] hover:text-[#E7EDF6] transition duration-150 ease-out">{social.label}</a>
      ))}
    </div>
  </div>
</footer>
