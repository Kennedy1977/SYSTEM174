---
const { title, description } = Astro.props;
---

<section class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8 py-14 sm:py-16 lg:py-24">
  {(title || description) && (
    <header class="mb-6 sm:mb-8">
      {title && <h2 class="font-display text-3xl md:text-4xl tracking-[-0.015em] uppercase">{title}</h2>}
      {description && <p class="mt-3 font-body text-[15px] leading-relaxed text-[#AAB6C6] max-w-2xl">{description}</p>}
    </header>
  )}
  <slot />
</section>
