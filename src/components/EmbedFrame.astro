---
const { title = "Embed", url } = Astro.props as {
  title?: string;
  url?: string;
};

const embedUrl = url
  ? `https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=%235CC8FF&auto_play=false&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false`
  : null;
---

<div class="rounded-2xl border border-white/10 bg-[#11151C]/70 shadow-[0_18px_60px_-30px_rgba(0,0,0,0.9)] p-5 sm:p-6">
  <p class="text-xs uppercase tracking-[0.2em] text-[#AAB6C6] font-mono">{title}</p>
  {
    embedUrl ? (
      <iframe
        class="mt-4 h-[166px] w-full rounded-xl border border-white/10 bg-[#1A2230]"
        title={title}
        src={embedUrl}
        loading="lazy"
        allow="autoplay"
      />
    ) : (
      <div class="mt-4 rounded-xl border border-white/10 bg-[#1A2230] p-10 text-sm text-[#AAB6C6]">No embed source available</div>
    )
  }
</div>
