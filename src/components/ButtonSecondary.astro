---
const { href, type = "button" } = Astro.props;
const cls = "inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold bg-[#1A2230] border border-white/10 text-[#E7EDF6] hover:bg-[#1A2230]/80 hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-[#5CC8FF]/40 focus:ring-offset-2 focus:ring-offset-[#0A0C10] transition duration-150 ease-out";
---

{href ? <a href={href} class={cls}><slot /></a> : <button type={type} class={cls}><slot /></button>}
