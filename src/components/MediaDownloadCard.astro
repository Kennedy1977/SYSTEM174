---
import ButtonSecondary from "./ButtonSecondary.astro";
const { item } = Astro.props;
---

<div class="rounded-2xl border border-white/10 bg-[#11151C]/70 shadow-[0_18px_60px_-30px_rgba(0,0,0,0.9)] p-5 sm:p-6">
  <p class="text-sm font-semibold tracking-tight text-[#E7EDF6]">{item.title}</p>
  <p class="mt-2 text-[15px] leading-relaxed text-[#AAB6C6]">{item.description}</p>
  <div class="mt-4">
    <ButtonSecondary>{item.action}</ButtonSecondary>
  </div>
</div>
