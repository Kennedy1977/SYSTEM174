---
const { href, type = "button" } = Astro.props;
const cls = "inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold border border-[#B8FF2C]/70 text-[#E7EDF6] hover:border-[#B8FF2C] hover:bg-[#B8FF2C]/10 focus:outline-none focus:ring-2 focus:ring-[#B8FF2C]/60 focus:ring-offset-2 focus:ring-offset-[#0A0C10] transition duration-150 ease-out";
---

{href ? <a href={href} class={cls}><slot /></a> : <button type={type} class={cls}><slot /></button>}
